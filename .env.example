# Live Trading Configuration (update these with your real values)
LIVE_HOST=127.0.0.1
LIVE_PORT=7496
LIVE_CLIENT_ID=1
LIVE_ACCOUNT=YOUR_LIVE_ACCOUNT_ID

# Optional settings
LOG_LEVEL=INFO