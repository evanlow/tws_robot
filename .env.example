# Interactive Brokers Configuration Template
# Copy this file to .env and update with your actual values
#
# ⚠️ IMPORTANT: Replace the account IDs below with YOUR account numbers.
#    Never commit your real .env file to version control.

# Trading Environment: 'paper' or 'live'
# This is the default - can be overridden with: python tws_client.py --env paper|live
TRADING_ENV=paper

# Paper Trading Configuration (Port 7497)
PAPER_HOST=127.0.0.1
PAPER_PORT=7497
PAPER_CLIENT_ID=0
PAPER_ACCOUNT=YOUR_PAPER_ACCOUNT_ID

# Live Trading Configuration (Port 7496)
LIVE_HOST=127.0.0.1
LIVE_PORT=7496
LIVE_CLIENT_ID=1
LIVE_ACCOUNT=YOUR_LIVE_ACCOUNT_ID

# Optional settings
LOG_LEVEL=INFO

# =============================================================================
# WEB AUTHENTICATION
# =============================================================================
# The web dashboard requires authentication by default.
# Set your admin credentials here or use the defaults (admin / changeme).
#
# TWS_ADMIN_USERNAME=admin
# TWS_ADMIN_PASSWORD=changeme
#
# To disable authentication for local-only development:
# LOGIN_DISABLED=true

# =============================================================================
# FLASK / APPLICATION
# =============================================================================
# Set ENVIRONMENT=production in production deployments to enable strict
# security checks (e.g. SECRET_KEY enforcement).
# ENVIRONMENT=production

# Flask session secret. MUST be set to a secure random value in production.
# SECRET_KEY=change-me

# AI / OpenAI Configuration
# Set your OpenAI API key here to auto-enable AI features (no UI toggle needed).
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# =============================================================================
# Cash Availability / Deployable Capital
# =============================================================================
# Reserve mode: gross_assignment (default) | net_premium | broker_margin
# CASH_RESERVE_MODE=gross_assignment
#
# Manual cash buffer — a portion of cash balance kept untouched.
# Either a percentage (e.g. 0.10 = 10%) or a fixed dollar amount (or both;
# the larger of the two is applied).
# MANUAL_CASH_BUFFER_PCT=0.05
# MANUAL_CASH_BUFFER_AMOUNT=0
#
# Default option-contract multiplier when not available from position data.
# OPTION_CONTRACT_MULTIPLIER_DEFAULT=100
#
# Safety guards — enable/disable automated-trading restrictions.
# ENABLE_CASH_AVAILABILITY_GUARD=true
# BLOCK_AUTOMATED_TRADING_IF_UNCOVERED_SHORT_CALL=true
# BLOCK_AUTOMATED_TRADING_IF_DEPLOYABLE_CASH_NEGATIVE=true

# =============================================================================
# USAGE
# =============================================================================
# Web dashboard (recommended):
#   python scripts/run_web.py
#   Open http://127.0.0.1:5000
#
# Terminal - Switch accounts without editing this file:
#   Paper trading (default):
#     python tws_client.py
#     python tws_client.py --env paper
#
#   Live trading:
#     python tws_client.py --env live
#
#   Show current configuration:
#     python tws_client.py --show-config
#
#   Other options:
#     python tws_client.py --timeout 60              # Run for 60 seconds
#     python tws_client.py --skip-market-check       # Skip market status check