# Interactive Brokers Configuration Template
# Copy this file to .env and update with your actual values
#
# ⚠️ IMPORTANT: Replace the account IDs below with YOUR account numbers.
#    Never commit your real .env file to version control.

# Trading Environment: 'paper' or 'live'
# This is the default - can be overridden with: python tws_client.py --env paper|live
TRADING_ENV=paper

# Paper Trading Configuration (Port 7497)
PAPER_HOST=127.0.0.1
PAPER_PORT=7497
PAPER_CLIENT_ID=0
PAPER_ACCOUNT=YOUR_PAPER_ACCOUNT_ID

# Live Trading Configuration (Port 7496)
LIVE_HOST=127.0.0.1
LIVE_PORT=7496
LIVE_CLIENT_ID=1
LIVE_ACCOUNT=YOUR_LIVE_ACCOUNT_ID

# Optional settings
LOG_LEVEL=INFO

# =============================================================================
# WEB AUTHENTICATION
# =============================================================================
# The web dashboard requires authentication by default.
# Set your admin credentials here or use the defaults (admin / changeme).
#
# TWS_ADMIN_USERNAME=admin
# TWS_ADMIN_PASSWORD=changeme
#
# Advanced: supply a pre-hashed bcrypt password instead of a plain-text one.
# Generate with: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('yourpassword'))"
# TWS_ADMIN_PASSWORD_HASH=pbkdf2:sha256:...
#
# Set to 'true' only in local development to keep the default password without
# a warning.  Never use in production.
# ALLOW_DEFAULT_PASSWORD=false
#
# To disable authentication for local-only development:
# LOGIN_DISABLED=true

# =============================================================================
# FLASK / APPLICATION
# =============================================================================
# Set ENVIRONMENT=production in production deployments to enable strict
# security checks (e.g. SECRET_KEY enforcement).
# ENVIRONMENT=production

# Flask session secret. MUST be set to a secure random value in production.
# SECRET_KEY=change-me

# AI / OpenAI Configuration
# Set your OpenAI API key here to auto-enable AI features (no UI toggle needed).
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
#
# Explicitly enable or disable AI features regardless of API key presence.
# Accepts: true / false (default: enabled when OPENAI_API_KEY is set)
# AI_ENABLED=true

# =============================================================================
# Cash Availability / Deployable Capital
# =============================================================================
# Reserve mode: gross_assignment (default) | net_premium | broker_margin
# CASH_RESERVE_MODE=gross_assignment
#
# Manual cash buffer — a portion of cash balance kept untouched.
# Either a percentage (e.g. 0.10 = 10%) or a fixed dollar amount (or both;
# the larger of the two is applied).
# MANUAL_CASH_BUFFER_PCT=0.05
# MANUAL_CASH_BUFFER_AMOUNT=0
#
# Default option-contract multiplier when not available from position data.
# OPTION_CONTRACT_MULTIPLIER_DEFAULT=100
#
# Safety guards — enable/disable automated-trading restrictions.
# ENABLE_CASH_AVAILABILITY_GUARD=true
# BLOCK_AUTOMATED_TRADING_IF_UNCOVERED_SHORT_CALL=true
# BLOCK_AUTOMATED_TRADING_IF_DEPLOYABLE_CASH_NEGATIVE=true

# =============================================================================
# AUTONOMOUS RUNNER
# =============================================================================
# The autonomous paper-trading runner is OFF by default.  Set this to 'true'
# to allow the runner to open and close positions automatically on the paper
# account.  Only takes effect with a paper account (paper_only=true always).
# Accepts: true / 1 / yes / on  (anything else keeps the runner disabled)
# AUTONOMOUS_RUNNER_ENABLED=false

# =============================================================================
# AUTONOMOUS LIVE RUNNER
# =============================================================================
# Full Live Continuous Autonomous Mode — OFF by default.
# All live-mode flags must be explicitly opted into.
#
# Master switches (both must be true for live continuous mode):
# AUTONOMOUS_LIVE_ENABLED=false
# AUTONOMOUS_LIVE_CONTINUOUS_ENABLED=false
#
# Deployable-cash sizing cap:
#   Each autonomous live trade is capped at this fraction of deployable cash.
#   Default: 10% (0.10).  Formula: max_trade_value = deployable_cash * cap
# AUTONOMOUS_MAX_DEPLOYABLE_CASH_PCT=0.10
# AUTONOMOUS_MIN_DEPLOYABLE_CASH=1000
#
# Concurrency and frequency limits:
# AUTONOMOUS_MAX_OPEN_LIVE_TRADES=1
# AUTONOMOUS_MAX_LIVE_TRADES_PER_DAY=1
#
# Order safety:
# AUTONOMOUS_LIVE_LIMIT_ORDERS_ONLY=true
# AUTONOMOUS_LIVE_REQUIRE_ACCOUNT_CONFIRMATION=true
#
# Dry-run mode: rehearse the full live lifecycle without sending orders.
# AUTONOMOUS_LIVE_DRY_RUN=false
#
# Live market data safety:
#   Actual-live autonomous trading requires a connected IBKR market-data
#   provider and rejects Yahoo/delayed/frozen quotes by default. Keep Yahoo as
#   research/recommend-only input only unless a future reviewed change says
#   otherwise.
# LIVE_MARKET_DATA_PROVIDER=ibkr
# ALLOW_YAHOO_FOR_LIVE_TRADING=false
# MAX_LIVE_QUOTE_AGE_SECONDS=5

# =============================================================================
# AUTONOMOUS POSITION SIZING CAPS (per new trade)
# =============================================================================
# Each new autonomous trade is capped at the LOWER of:
#   * deployable_cash * AUTONOMOUS_MAX_POSITION_DEPLOYABLE_CASH_PCT
#   * equity          * AUTONOMOUS_MAX_POSITION_EQUITY_PCT
#
# Both fall back to AUTONOMOUS_MAX_NEW_POSITION_PCT (default 0.10 / 10 %)
# when unset, which historically applied the same percentage to both
# sides.  Override them independently if a tight deployable-cash cap
# blocks single-share buys of high-priced names while you still want a
# tight equity guard on total exposure.  All three are fractions in (0, 1].
# AUTONOMOUS_MAX_NEW_POSITION_PCT=0.10
# AUTONOMOUS_MAX_POSITION_DEPLOYABLE_CASH_PCT=0.25
# AUTONOMOUS_MAX_POSITION_EQUITY_PCT=0.10

# =============================================================================
# AUTONOMOUS EXIT TARGET / ADR SETTINGS
# =============================================================================
# Target mode determines how the autonomous planner calculates exit prices:
#   resistance    — use nearest resistance level above entry (default)
#   percent       — fixed percentage above entry (AUTONOMOUS_TAKE_PROFIT_PCT)
#   adr_intraday  — ADR-based dynamic intraday target with caps/floors
# AUTONOMOUS_EXIT_TARGET_MODE=resistance
#
# Fixed percentage target (used in 'percent' mode and as fallback):
# AUTONOMOUS_TAKE_PROFIT_PCT=0.08
#
# ADR calculation — number of trading days of daily bars to average:
# AUTONOMOUS_ADR_LOOKBACK_DAYS=14
#
# Fraction of ADR to target (e.g. 0.50 = aim for 50% of the daily range):
# AUTONOMOUS_ADR_TARGET_FRACTION=0.50
#
# Caps/floors for the ADR-derived target move as a fraction of entry price:
# AUTONOMOUS_ADR_MAX_TARGET_PCT=0.03
# AUTONOMOUS_ADR_MIN_TARGET_PCT=0.005
#
# When true and resistance is available below the ADR target, cap at resistance:
# AUTONOMOUS_ADR_RESPECT_RESISTANCE_CAP=true
#
# Profit-based exit — close when unrealized P/L reaches this USD threshold.
# Default is 100. Set lower (e.g. 50) for earlier profit harvesting.
# AUTONOMOUS_MIN_PROFIT_THRESHOLD_USD=100

# =============================================================================
# DATABASE
# =============================================================================
# SQLAlchemy-compatible connection string.  When unset, SQLite is used and
# the database file is placed in the project root.
# DATABASE_URL=sqlite:///tws_robot.db
# DATABASE_URL=postgresql://user:password@localhost:5432/tws_robot

# =============================================================================
# FX RESEARCH MODULE
# =============================================================================
# Data mode for the FX research dashboard.
#   not_configured  — empty safe default (default when unset)
#   demo            — deterministic sample data (no network calls)
#   live_research   — fetch live/delayed data from the configured provider
# FX_DATA_MODE=not_configured
#
# FX data provider.  Currently only 'yfinance' is supported.
# FX_PROVIDER=yfinance
#
# Timeout in seconds for FX provider HTTP requests (default: 10).
# FX_PROVIDER_TIMEOUT_SECONDS=10

# =============================================================================
# FILE PATHS (optional overrides)
# =============================================================================
# Path to the emergency-stop sentinel file.  When this file exists, automated
# trading is halted immediately.  Defaults to EMERGENCY_STOP in the project root.
# EMERGENCY_STOP_FILE=/var/run/tws_robot/EMERGENCY_STOP
#
# Path to the disclaimer acceptance record JSON file.
# DISCLAIMER_ACCEPTANCE_FILE=disclaimer_acceptance.json
#
# Path to the strategy lifecycle SQLite database.
# STRATEGY_DB_PATH=strategy_lifecycle.db

# =============================================================================
# USAGE
# =============================================================================
# Web dashboard (recommended):
#   python scripts/run_web.py
#   Open http://127.0.0.1:5000
#
# Terminal - Switch accounts without editing this file:
#   Paper trading (default):
#     python tws_client.py
#     python tws_client.py --env paper
#
#   Live trading:
#     python tws_client.py --env live
#
#   Show current configuration:
#     python tws_client.py --show-config
#
#   Other options:
#     python tws_client.py --timeout 60              # Run for 60 seconds
#     python tws_client.py --skip-market-check       # Skip market status check
