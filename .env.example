# Interactive Brokers Configuration Template
# Copy this file to .env and update with your actual values

# Trading Environment: 'paper' or 'live'
TRADING_ENV=paper

# Paper Trading Configuration
PAPER_HOST=127.0.0.1
PAPER_PORT=7497
