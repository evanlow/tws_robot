# TWS Robot Production Environment Configuration
# Copy this file to .env.production and fill in your values

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=production
LOG_LEVEL=INFO

# =============================================================================
# TWS CONNECTION (Paper Trading - for 30-day validation)
# =============================================================================
TWS_HOST=127.0.0.1
TWS_PORT=7497
TWS_CLIENT_ID=1
IB_ACCOUNT=DU2746208

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
# Option 1: Local PostgreSQL (if installed)
# DATABASE_URL=postgresql://tws_user:your_password@localhost:5432/tws_robot_prod

# Option 2: Docker PostgreSQL (recommended for local deployment)
DATABASE_URL=postgresql://tws_user:tws_secure_password@localhost:5432/tws_robot_prod

# Database Pool Settings (for production load)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# =============================================================================
# REDIS CACHE (Optional but recommended)
# =============================================================================
# Option 1: Docker Redis
REDIS_URL=redis://localhost:6379/0

# Option 2: No Redis (will use in-memory caching)
# REDIS_URL=

# =============================================================================
# RISK LIMITS (Conservative for paper trading validation)
# =============================================================================
MAX_DAILY_LOSS=0.02          # 2% max daily loss
MAX_POSITION_SIZE=0.05       # 5% max per position
MAX_PORTFOLIO_HEAT=0.15      # 15% total portfolio risk
RISK_FREE_RATE=0.05          # 5% risk-free rate for Sharpe calculation

# =============================================================================
# VALIDATION CRITERIA (30-day validation requirements)
# =============================================================================
MIN_VALIDATION_DAYS=30       # Minimum days before live trading
MIN_SHARPE_RATIO=1.0         # Minimum Sharpe ratio
MAX_DRAWDOWN=0.10            # Maximum 10% drawdown
MIN_WIN_RATE=0.50            # Minimum 50% win rate

# =============================================================================
# MONITORING & ALERTS
# =============================================================================
# Slack Webhook (optional - for alerts)
SLACK_WEBHOOK_URL=

# Email Alerts (optional)
EMAIL_SMTP_SERVER=
EMAIL_USERNAME=
EMAIL_PASSWORD=
ALERT_EMAIL_TO=

# Monitoring Dashboard Port
DASHBOARD_PORT=8080

# =============================================================================
# BACKUP & LOGGING
# =============================================================================
# Log Directory
LOG_DIR=./logs

# Database Backup Directory
BACKUP_DIR=./backups

# Backup Schedule (daily at 2 AM)
BACKUP_ENABLED=true
BACKUP_HOUR=2

# =============================================================================
# SAFETY CONTROLS
# =============================================================================
# Emergency Stop (set to true to halt all trading)
EMERGENCY_STOP=false

# Dry Run Mode (set to true to simulate without actual orders)
DRY_RUN=false

# Paper Trading Mode (keep true for 30-day validation)
PAPER_TRADING=true
